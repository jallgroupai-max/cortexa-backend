generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String
  plan      String   @default("Free")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile              Profile?
  usage                UserUsage?
  agents               Agent[]
  workflows            Workflow[]
  ownedWorkspaces      Workspace[]        @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]  @relation("MemberUser")
  billingOrders        BillingOrder[]

  @@map("users")
}

model UserUsage {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  tokensUsedDay   Int      @default(0) @map("tokens_used_day")
  tokensUsedMonth Int      @default(0) @map("tokens_used_month")
  requestsToday   Int      @default(0) @map("requests_today")
  lastResetDay    DateTime @default(now()) @map("last_reset_day")
  lastResetMonth  DateTime @default(now()) @map("last_reset_month")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_usage")
}

model Profile {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  coverPreset  String?  @map("cover_preset")
  company      String?
  phone        String?
  address      String?
  bio          String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  icon      String?  @default("FolderKanban")
  ownerId   String   @map("owner_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  agents  Agent[]
  workflows Workflow[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(uuid()) @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  email       String
  permission  String   @default("view") // "view" | "edit"
  status      String   @default("pending") // "pending" | "accepted"
  invitedAt   DateTime @default(now()) @map("invited_at")

  workspace          Workspace                   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user               User                        @relation("MemberUser", fields: [userId], references: [id], onDelete: Cascade)
  agentPermissions   MemberAgentPermission[]
  workflowPermissions MemberWorkflowPermission[]

  @@unique([workspaceId, email])
  @@map("workspace_members")
}

model Agent {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  workspaceId    String?  @map("workspace_id") @db.Uuid
  name           String
  description    String?  @default("")
  tone           String?  @default("profesional")
  color          String?  @default("#7C3AED")
  welcomeMessage String?  @map("welcome_message") @default("¡Hola! ¿En qué puedo ayudarte hoy?")
  prompt         String?  @default("Eres un asistente de IA útil y amable.")
  model          String?  @default("DeepSeek V3.2")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  knowledgeSources  KnowledgeSource[]
  memberPermissions MemberAgentPermission[]
  conversations     Conversation[]

  @@index([userId])
  @@index([workspaceId])
  @@map("agents")
}

model Conversation {
  id          String   @id @default(uuid()) @db.Uuid
  agentId     String   @map("agent_id") @db.Uuid
  visitorName String   @default("Visitante") @map("visitor_name")
  visitorId   String?  @map("visitor_id")
  channel     String   @default("web")
  status      String   @default("open")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  agent    Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([agentId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  role           String
  content        String
  tokensUsed     Int?     @map("tokens_used")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model KnowledgeSource {
  id           String   @id @default(uuid()) @db.Uuid
  agentId      String   @map("agent_id") @db.Uuid
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  fileType     String   @map("file_type")
  fileSize     Int?     @map("file_size")
  status       String   @default("Procesando")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("knowledge_sources")
}

model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  workspaceId String?  @map("workspace_id") @db.Uuid
  name        String   @default("Nuevo Workflow")
  description String?  @default("")
  nodes       Json     @default("[]")
  edges       Json     @default("[]")
  status      String   @default("draft") // "draft" | "active" | "paused"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user              User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace?                 @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  memberPermissions MemberWorkflowPermission[]

  @@index([userId])
  @@index([workspaceId])
  @@map("workflows")
}

model MemberAgentPermission {
  id       String @id @default(uuid()) @db.Uuid
  memberId String @map("member_id") @db.Uuid
  agentId  String @map("agent_id") @db.Uuid

  member WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  agent  Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([memberId, agentId])
  @@map("member_agent_permissions")
}

model MemberWorkflowPermission {
  id         String @id @default(uuid()) @db.Uuid
  memberId   String @map("member_id") @db.Uuid
  workflowId String @map("workflow_id") @db.Uuid

  member   WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workflow Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([memberId, workflowId])
  @@map("member_workflow_permissions")
}

model BillingOrder {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  description String   @default("")
  amount      Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("USD")
  status      String   @default("pending") // "pending" | "approved" | "rejected"
  receiptUrl  String?  @map("receipt_url")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("billing_orders")
}
